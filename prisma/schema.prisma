generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id          Int      @id @default(autoincrement())
  title       String
  filePath    String
  mimeType    String
  version     Int      @default(1)
  hash        String?
  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

# Database
DATABASE_URL="mysql://root:password@127.0.0.1:3306/docflow"

# Redis
REDIS_URL="redis://127.0.0.1:6379"

# Feishu / 飞书集成
FEISHU_APP_ID="cli_a9339abde778dbd7"
FEISHU_APP_SECRET="your-app-secret-here"
FEISHU_WEBHOOK_URL="https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token"
FEISHU_SITE_URL="http://localhost:3000"

# App
APP_ENV="local"

# Auth — 双令牌模式
JWT_SECRET="change-this-to-a-random-string-at-least-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS — 多个 origin 用逗号分隔，留空则仅允许同源
ALLOWED_ORIGINS=""

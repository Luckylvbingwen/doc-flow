    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "diff": "^8.0.4",
    "element-plus": "^2.13.6",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.1",
    "nprogress": "^0.2.0",
    "nuxt": "^3.21.2",
    "nuxt-security": "^2.5.1",
    "pdf-parse": "^2.4.5",

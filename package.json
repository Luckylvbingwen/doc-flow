{
  "name": "docflow",
  "version": "1.0.0",
  "description": "DocFlow monorepo-like fullstack starter built with Nuxt3 + Nitro + Prisma",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/api",
    "test:coverage": "vitest run --coverage",
    "postinstall": "nuxt prepare",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "nuxt3",
    "nitro",
    "prisma",
    "mysql",
    "pinia",
    "element-plus"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
